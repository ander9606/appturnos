# URL del backend (sin slash final) — REQUERIDO
# Esta variable DEBE estar configurada o la app no arranca.

# Desarrollo local con Expo en el mismo equipo:
EXPO_PUBLIC_API_URL=http://localhost:3001

# Expo Go en dispositivo físico (usa la IP de tu máquina, no localhost):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001

# Producción:
# EXPO_PUBLIC_API_URL=https://api.tudominio.com
