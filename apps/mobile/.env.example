# URL del backend (sin slash final) — REQUERIDO
# Esta variable DEBE estar configurada o la app no arranca.

# Desarrollo local con Expo en el mismo equipo:
EXPO_PUBLIC_API_URL=http://localhost:3001

# Expo Go en dispositivo físico (usa la IP de tu máquina, no localhost):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001

# Producción:
# EXPO_PUBLIC_API_URL=https://api.zaturno.app

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — Login con Google (opcional)
# ─────────────────────────────────────────────────────────────────────────────
# Cómo obtener las credenciales:
#   1. Ve a https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Crea un proyecto (o usa uno existente) y activa la "Google Sign-In API"
#   3. Crea credenciales "OAuth 2.0 Client ID" para cada plataforma:
#
#   WEB (requerido para Expo Go y desarrollo):
#     - Tipo: Web application
#     - URI de redirección autorizado: https://auth.expo.io/@TU_USUARIO_EXPO/zaturno
#       Reemplaza TU_USUARIO_EXPO con tu cuenta Expo (p.ej. @anderson960616).
#       También agrega: http://localhost (para pruebas en emulador)
#
#   iOS (requerido solo para build nativo con EAS / Xcode):
#     - Tipo: iOS
#     - Bundle ID: debe coincidir con el "bundleIdentifier" en app.json
#
#   ANDROID (requerido solo para build nativo con EAS / Android Studio):
#     - Tipo: Android
#     - Package name: debe coincidir con "package" en app.json
#     - SHA-1 fingerprint: obtenlo con `eas credentials` (EAS) o `keytool`
#
#   NOTA BACKEND: en backend/.env, configura GOOGLE_CLIENT_ID con todos los
#   Client IDs separados por coma para que el servidor pueda verificar tokens
#   de cualquier plataforma:
#   GOOGLE_CLIENT_ID=web_client_id,ios_client_id,android_client_id

EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
