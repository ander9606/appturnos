# URL del backend (sin slash final) — REQUERIDO
# Esta variable DEBE estar configurada o la app no arranca.

# Desarrollo local con Expo en el mismo equipo:
EXPO_PUBLIC_API_URL=http://localhost:3001

# Expo Go en dispositivo físico (usa la IP de tu máquina, no localhost):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3001

# Producción:
# EXPO_PUBLIC_API_URL=https://api.zaturno.app

# Sentry — monitoreo de errores/crashes en producción (opcional, pero recomendado).
# Crear proyecto en sentry.io con plataforma "React Native".
EXPO_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# Google OAuth — Login con Google (opcional)
# ─────────────────────────────────────────────────────────────────────────────
# Usa el SDK nativo (@react-native-google-signin/google-signin), que valida
# por SHA-1 + package name en vez de redirect URIs. El único ID que lee el
# código de la app es el WEB — Play Services resuelve el resto por la firma.
#
#   1. Ve a https://console.cloud.google.com/ → APIs & Services → Credentials
#   2. Client ID tipo "Web application" → copialo aquí abajo. Este mismo ID
#      es el que el backend usa como audience para verificar el id_token
#      (backend/.env → GOOGLE_CLIENT_ID).
#   3. Además crea un Client ID tipo "Android" (Package name = "package" en
#      app.json, SHA-1 = `eas credentials` o `keytool`) — Google lo exige
#      para autorizar la app aunque el código no lo referencie directamente.

EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
