# Archivos de texto — normalizar a LF en el repo
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sql   text eol=lf
*.env*  text eol=lf
*.sh    text eol=lf

# Binarios — nunca tocar los line endings
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
*.zip   binary
*.apk   binary
