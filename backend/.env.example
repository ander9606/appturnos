# ──────────────────────────────────────────────────────────────
# App Turnos Backend — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commits el .env con valores reales al repositorio.
# ──────────────────────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=production
# Zona horaria del servidor — DEBE coincidir con la zona horaria de los trabajadores.
# Si el servidor corre en UTC y los trabajadores están en Colombia, las horas de
# marcaje (hora_entrada / hora_salida) se guardan en UTC generando un desfase de 5 h.
TZ=America/Bogota

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=appturnos
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_ROOT_SEGURO
DB_NAME=app_turnos

# Auth — generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_DE_64_CHARS_MINIMO
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DIAS=7

# CORS — orígenes permitidos, separados por coma.
# En desarrollo puedes dejarlo vacío (acepta todo).
# En producción DEBE incluir el dominio de tu frontend/app.
CORS_ORIGINS=https://zaturno.app

# URL pública de este servidor — REQUERIDA para el emparejamiento con logiq360.
# Sin este valor, app_turnos_base_url no se envía a logiq360 y la integración queda inactiva.
# Ejemplo: https://api.appturnos.com  (sin slash al final)
PUBLIC_API_URL=https://tu-dominio.com

# Integración logiq360 (opcional)
LOGIQ360_WEBHOOK_SECRET=
LOGIQ360_API_KEY=

# Web Push (notificaciones del navegador) — opcional
# Generar con: npm run generar-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@zaturno.app

# OAuth — Login con Google (opcional)
# Obtener en https://console.cloud.google.com/apis/credentials
#
# Puedes poner múltiples Client IDs separados por coma (web, iOS, Android).
# El servidor acepta tokens de cualquiera de los IDs listados.
# Ejemplo: GOOGLE_CLIENT_ID=111.apps.googleusercontent.com,222.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# Email — envío de emails OTP (verificación de correo)
# Proveedor recomendado: Resend (https://resend.com)
#   1. Crea una cuenta en resend.com
#   2. Verifica el dominio zaturno.app en DNS → Settings → Domains
#   3. Genera una API key en Settings → API Keys
#   4. Pega la key en SMTP_PASS
#
# Alternativas: Gmail (smtp.gmail.com:587), SendGrid, Brevo — misma config SMTP.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_TU_API_KEY_DE_RESEND
SMTP_FROM="Zaturno <no-reply@zaturno.app>"

# Twilio — envío de SMS OTP (verificación de teléfono)
# Obtener en https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
