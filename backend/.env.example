# ──────────────────────────────────────────────────────────────
# App Turnos Backend — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA commits el .env con valores reales al repositorio.
# ──────────────────────────────────────────────────────────────

# Servidor
PORT=3001
NODE_ENV=production

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=appturnos
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
DB_ROOT_PASSWORD=CAMBIAR_POR_PASSWORD_ROOT_SEGURO
DB_NAME=app_turnos

# Auth — generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_DE_64_CHARS_MINIMO
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DIAS=7

# CORS — orígenes permitidos, separados por coma.
# En desarrollo puedes dejarlo vacío (acepta todo).
# En producción DEBE incluir el dominio de tu frontend/app.
CORS_ORIGINS=https://tudominio.com

# Integración logiq360 (opcional)
LOGIQ360_WEBHOOK_SECRET=
LOGIQ360_API_KEY=

# Web Push (notificaciones del navegador) — opcional
# Generar con: npm run generar-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@tudominio.com

# OAuth — Login con Google (opcional)
# Obtener en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
