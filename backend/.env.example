# Servidor
PORT=3001
NODE_ENV=development

# Base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=app_turnos

# Auth
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_DIAS=7

# Integración logiq360 (opcional)
LOGIQ360_WEBHOOK_SECRET=
LOGIQ360_API_KEY=

# Web Push (notificaciones del navegador) — opcional
# Generar las claves con: npm run generar-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@app-turnos.com

# OAuth — Login con Google (opcional)
# Uno o varios client_id separados por coma (iOS, Android, Web).
# Obtener en https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
